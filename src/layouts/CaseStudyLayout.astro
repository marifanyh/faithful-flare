---
import "../styles/tokens.css";
import "../styles/base.css";
import "../styles/case-study.css";
import FontLinks from "../components/FontLinks.astro";
import CaseStudyNav from "../components/CaseStudyNav.astro";
import ThemeLangScript from "../components/ThemeLangScript.astro";

interface Props {
  title: string;
  activeBreadcrumbEs: string;
  activeBreadcrumbEn?: string;
}

const { title, activeBreadcrumbEs, activeBreadcrumbEn } = Astro.props;
---

<!DOCTYPE html>
<html lang="es" data-theme="light">
  <head>
    <meta charset="utf-8" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="color-scheme" content="light dark" />
    <title>{title}</title>
    <FontLinks />
  </head>
  <body class="layout-case-study">
    <CaseStudyNav activeEs={activeBreadcrumbEs} activeEn={activeBreadcrumbEn} />
    <slot />
    <ThemeLangScript revealThreshold={0.05} />
  </body>
</html>
