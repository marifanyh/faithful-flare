          <svg width="11" height="11" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><circle cx="12" cy="8" r="4"/><path d="M20 21a8 8 0 10-16 0"/></svg>
          <span class="label" data-es="Rol:" data-en="Role:">Rol:</span>
          <span data-es="UX/UI Practice Lead · LabComm" data-en="UX/UI Practice Lead · LabComm">UX/UI Practice Lead · LabComm</span>
        </div>
        <div class="meta-pill">
          <svg width="11" height="11" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M20 7H4a2 2 0 00-2 2v6a2 2 0 002 2h16a2 2 0 002-2V9a2 2 0 00-2-2z"/><path d="M16 21V5a2 2 0 00-2-2h-4a2 2 0 00-2 2v16"/></svg>
          <span class="label" data-es="Cliente:" data-en="Client:">Cliente:</span>
          Universidad Panamericana · LabComm
        </div>
        <div class="meta-pill">
          <svg width="11" height="11" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><rect x="3" y="4" width="18" height="18" rx="2"/><line x1="16" y1="2" x2="16" y2="6"/><line x1="8" y1="2" x2="8" y2="6"/><line x1="3" y1="10" x2="21" y2="10"/></svg>
          <span class="label" data-es="Período:" data-en="Period:">Período:</span>
          Ene 2026 – Mar 2026
        </div>
