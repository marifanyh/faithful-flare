---
import PortfolioLayout from "../layouts/PortfolioLayout.astro";
import PortfolioHeroToggles from "../components/PortfolioHeroToggles.astro";
---

<PortfolioLayout
  title="Mariana Hernández · Senior Product Designer"
  preloadImageSrcSet="/profile-hero-1x.jpg 480w, /profile-hero-2x.jpg 900w"
  preloadImageSizes="(max-width: 479px) 100px, (max-width: 767px) 120px, 150px"
>
  <!-- ── HERO HEADER ── -->
  <header class="hero">
    <div class="orb3"></div>
    <div class="hero-inner">

      <div class="hero-identity">
        <div class="photo-blob">
          <img
            src="/profile-hero-2x.jpg"
            srcset="/profile-hero-1x.jpg 480w, /profile-hero-2x.jpg 900w"
            sizes="(max-width: 479px) 100px, (max-width: 767px) 120px, 150px"
            width="900"
            height="1200"
            alt="Mariana Hernández"
            fetchpriority="high"
            decoding="async"
            onerror="this.onerror=null;this.src='/profile.png'"
          />
        </div>
        <div class="hero-text">
          <h1 class="name"><span class="first">Mariana</span> <span class="last">Hernández</span></h1>
          <p class="subtitle" data-es="Senior Product Designer" data-en="Senior Product Designer">Senior Product Designer</p>
