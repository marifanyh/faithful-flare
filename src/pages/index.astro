            <span class="project-arrow">↗</span>
          </div>
        </a>

        <!-- 2. Investigación UP -->
        <a href="/proyecto-3" class="project-card">
          <div class="project-cover cover-investigacion">
            <img class="cover-photo" src="/portada-investigacion-light.png" data-light="/portada-investigacion-light.png" data-dark="/portada-investigacion-dark.png" alt="Investigación UP" loading="lazy" decoding="async" />
          </div>
          <div class="project-body">
            <span class="project-tag" data-es="Educación · Portal Institucional" data-en="Education · Institutional Portal">Educación · Portal Institucional</span>
            <div class="project-title" data-es="Investigación UP: Del repositorio al ecosistema digital" data-en="UP Research: From repository to digital ecosystem">Investigación UP: Del repositorio al ecosistema digital</div>
            <p class="project-desc" data-es="5 entrevistas, Empathy Maps, VPC, user personas, IA y 17 mockups finales — de repositorio estático a vitrina de talento" data-en="5 interviews, Empathy Maps, VPC, user personas, IA and 17 final mockups — from static repository to living talent showcase">5 entrevistas, Empathy Maps, VPC, user personas, IA y 17 mockups finales — de repositorio estático a vitrina de talento</p>
            <span class="project-arrow">↗</span>
          </div>
        </a>

        <!-- 3. UNIMOPAY -->
        <a href="/proyecto-1" class="project-card">
          <div class="project-cover cover-unimopay">
            <img class="cover-photo" src="/portada-unimopay-light.png" data-light="/portada-unimopay-light.png" data-dark="/portada-unimopay-dark.png" alt="UNIMOPAY" loading="lazy" decoding="async" />
          </div>
          <div class="project-body">
            <span class="project-tag" data-es="B2B · Fintech Educativo" data-en="B2B · Educational Fintech">B2B · Fintech Educativo</span>
