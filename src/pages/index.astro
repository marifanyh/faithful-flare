            <span class="project-arrow">↗</span>
          </div>
        </a>

        <!-- 6. Design System minu -->
        <a href="/proyecto-6" class="project-card">
          <div class="project-cover cover-minu">
            <img class="cover-photo" src="/portada-minu-light.png" data-light="/portada-minu-light.png" data-dark="/portada-minu-dark.png" alt="minu Design System" loading="lazy" decoding="async" />
